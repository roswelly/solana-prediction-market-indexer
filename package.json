{
  "name": "solana-prediction-market-indexer",
  "version": "0.1.0",
  "private": true,
  "description": "End-to-end Solana prediction market stack: Anchor AMM program, chain indexer, REST/WS API, and automated market-maker + arbitrage trading bot.",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc -b",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint \"packages/*/src/**/*.ts\"",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "indexer:dev": "npm run dev --workspace @spmi/indexer",
    "api:dev": "npm run dev --workspace @spmi/api",
    "bot:dev": "npm run dev --workspace @spmi/bot",
    "db:migrate": "node scripts/migrate.mjs",
    "db:seed": "node --loader ts-node/esm scripts/seed-mock.ts",
    "anchor:build": "anchor build",
    "anchor:test": "anchor test"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=20"
  }
}
