# ---------- Solana RPC ----------
SOLANA_RPC_HTTP=https://api.devnet.solana.com
SOLANA_RPC_WS=wss://api.devnet.solana.com
# Optional: Helius / Triton / QuickNode for production workloads
HELIUS_API_KEY=

# Geyser gRPC (Yellowstone). Leave empty to use WebSocket adapter.
GEYSER_GRPC_ENDPOINT=
GEYSER_GRPC_TOKEN=

# ---------- Program ----------
PREDICTION_MARKET_PROGRAM_ID=PMrkt1111111111111111111111111111111111111
# Commitment level used for subscriptions and confirmations
COMMITMENT=confirmed

# ---------- Database ----------
DATABASE_URL=postgres://spmi:spmi@localhost:5432/spmi
REDIS_URL=redis://localhost:6379

# ---------- API ----------
API_HOST=0.0.0.0
API_PORT=4000
API_CORS_ORIGIN=*

# ---------- Indexer ----------
INDEXER_BACKFILL_SLOTS=5000
INDEXER_ADAPTER=websocket        # websocket | geyser
INDEXER_CONCURRENCY=8

# ---------- Bot ----------
BOT_ENABLED=true
BOT_KEYPAIR_PATH=./wallets/bot.json
BOT_STRATEGIES=market_maker,arbitrage
BOT_MAX_POSITION_USD=250
BOT_MAX_DAILY_LOSS_USD=100
BOT_QUOTE_SPREAD_BPS=80          # 0.80% half-spread per side
BOT_ARB_MIN_EDGE_BPS=35          # only trade when >= 0.35% edge after fees

# ---------- Observability ----------
LOG_LEVEL=info
METRICS_PORT=9464
